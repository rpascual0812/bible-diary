# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYMONGO_SECRET_KEY: Used on the server-side server.ts to request Checkout Sessions from PayMongo.
# Generate this in your PayMongo dashboard under Developers -> API keys.
# Set it in the Secrets/Settings panel of AI Studio.
PAYMONGO_SECRET_KEY=

# PAYMONGO_PUBLIC_KEY: Used on the client side if doing direct tokenization (optional).
PAYMONGO_PUBLIC_KEY=

# Bank Transfer and GCash Configuration (Client-side accessible)
VITE_BANK_NAME=
VITE_BANK_ACCOUNT_NAME=
VITE_BANK_ACCOUNT_NUMBER=
VITE_GCASH_NUMBER=
VITE_GCASH_NAME=

# External API URLs
VITE_BIBLE_API_URL=
PAYMONGO_API_URL=

# Native mobile (Expo Go / dev builds): backend URL for PayMongo checkout.
# If unset, the app auto-detects your computer's IP from the Expo dev server.
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
EXPO_PUBLIC_API_URL=

# Web/APK dev fallback when Expo host detection is unavailable (Android emulator default).
VITE_PAYMONGO_DEV_SERVER_URL=http://10.0.2.2:3000
VITE_PAYMONGO_PROD_SERVER_URL=

