# GEMINI_API_KEY: Required for Gemini AI (web + Expo). One variable is enough —
# app.config.js copies it into the native bundle for `npx expo start`.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Optional alias (Expo also reads this directly if set):
# EXPO_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"
#
# EAS APK / production builds: .env is not uploaded. Create the same variable on EAS:
#   eas env:create --name GEMINI_API_KEY --value YOUR_KEY --environment preview --environment production
# Then rebuild the APK.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# XENDIT_SECRET_KEY: Used on the server-side server.ts to create Xendit Payment Sessions.
# Generate this in your Xendit dashboard under Settings -> Developers -> API Keys.
XENDIT_SECRET_KEY=

# XENDIT_TEST_SECRET_KEY: Development/test key (starts with xnd_development_).
XENDIT_TEST_SECRET_KEY=

# Bank Transfer and GCash Configuration (Client-side accessible)
VITE_BANK_NAME=
VITE_BANK_ACCOUNT_NAME=
VITE_BANK_ACCOUNT_NUMBER=
VITE_GCASH_NUMBER=
VITE_GCASH_NAME=

# External API URLs
VITE_BIBLE_API_URL=
XENDIT_API_URL=

# Native mobile (Expo Go / dev builds): backend URL for Xendit checkout.
# If unset, the app auto-detects your computer's IP from the Expo dev server.
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
EXPO_PUBLIC_API_URL=

# Web/APK dev fallback when Expo host detection is unavailable (Android emulator default).
VITE_PAYMENT_DEV_SERVER_URL=http://10.0.2.2:3000
VITE_PAYMENT_PROD_SERVER_URL=
