{
  "name": "Daily Healing Word",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build:web": "vite build",
    "build:mobile-web": "cross-env MOBILE_BUILD=true vite build",
    "build": "npm run build:web && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:mobile": "node scripts/generate-expo-icons.cjs && npm run build:mobile-web && node scripts/prepare-native-web.cjs",
    "postinstall": "node scripts/eas-postinstall.cjs",
    "start": "node dist/server.cjs",
    "mobile": "expo start -c",
    "mobile:lan": "expo start -c --lan",
    "mobile:tunnel": "expo start -c --tunnel",
    "android": "expo run:android",
    "generate:icons": "node scripts/generate-expo-icons.cjs",
    "expo:prebuild": "npm run generate:icons && expo prebuild",
    "clean": "rm -rf dist server.js assets/web android ios",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@google/genai": "^1.29.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-preset-expo": "^56.0.14",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "expo": "~56.0.12",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "^56.0.7",
    "expo-network": "~56.0.5",
    "expo-sharing": "~56.0.18",
    "expo-status-bar": "^56.0.4",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "punycode": "^2.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-native": "0.85.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-webview": "^13.16.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.14",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^6.2.3",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
